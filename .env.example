# Copy to ".env" in this folder (repo root). Docker Compose loads it for variable substitution.
# Ollama must be running on your Mac (default http://127.0.0.1:11434); the API container uses host.docker.internal.

CONTEXT_PROVIDER=ollama
OLLAMA_MODEL=llama3.1:8b

# Optional (ingest uses NewsAPI when set; otherwise you see newsapi_status: missing_key):
# NEWSAPI_KEY=your_key_from_https://newsapi.org/register
# OPENAI_API_KEY=
# CONTEXT_PROVIDER=openai
# CONTEXT_MODEL=gpt-4.1-mini
