DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/portfolio_intel
OPENAI_API_KEY=
FIREBASE_PROJECT_ID=
RESEND_API_KEY=
SLACK_BOT_TOKEN=
APP_BASE_URL=http://localhost:8000
CONTEXT_PROVIDER=fallback
CONTEXT_MODEL=gpt-4.1-mini
NEWSAPI_KEY=
NEWSAPI_URL=https://newsapi.org/v2/everything
# Fallback NewsAPI `q` when no context profiles or NEWSAPI_USE_CONTEXT_QUERY=false
NEWSAPI_QUERY=private equity OR portfolio company OR M&A OR funding
NEWSAPI_PAGE_SIZE=25
# Each page = one API request. Free tier is ~100 requests/day — keep low.
NEWSAPI_MAX_PAGES=2
NEWSAPI_USE_CONTEXT_QUERY=true
NEWSAPI_QUERY_MAX_CHARS=500
NEWSAPI_CONTEXT_KEYWORD_BUDGET=40
NEWSAPI_INGEST_TARGET_ARTICLES=40
NEWSAPI_MAX_REQUEST_BATCHES=8
NEWSAPI_CONTEXT_SORT_BY=relevancy
# Ollama: equal per-context search keywords for NewsAPI (requires Ollama running if true)
NEWSAPI_USE_OLLAMA_KEYWORDS=true
NEWSAPI_OLLAMA_KEYWORD_TIMEOUT=90
# Two-phase: direct entity terms → NewsAPI, then broad terms → NewsAPI, then brief Ollama semantic filter on broad-only.
NEWSAPI_TWO_PHASE_INGEST=true
NEWSAPI_DIRECT_TERM_MAX=28
NEWSAPI_BROAD_TERM_MAX=48
NEWSAPI_DIRECT_ARTICLE_CAP=18
NEWSAPI_BROAD_ARTICLE_CAP=32
NEWSAPI_MAX_BATCHES_DIRECT=5
NEWSAPI_MAX_BATCHES_BROAD=8
NEWSAPI_SEMANTIC_ENABLED=true
NEWSAPI_SEMANTIC_BATCH_SIZE=10
NEWSAPI_SEMANTIC_SNIPPET_CHARS=200
NEWSAPI_SEMANTIC_CONTEXT_MAX_CHARS=3200
NEWSAPI_SEMANTIC_OLLAMA_NUM_PREDICT=280
NEWSAPI_SEMANTIC_TIMEOUT=48
NEWSAPI_SEMANTIC_MIN_SCORE=0.42
STAGE1_MAX_FETCH=1000
STAGE1_CANDIDATE_LIMIT=250
STAGE1_DAYS_BACK=7
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

